<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" version="29.6.1">
  <diagram id="event-queues-how-it-works" name="Page-1">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Participant heads -->
        <mxCell id="p_handler" value="Handler" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="80" y="40" width="140" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="p_db" value="Database" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=14;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="320" y="40" width="140" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="p_runner" value="Background runner" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="560" y="40" width="180" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="p_svc" value="Remote service" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=14;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="820" y="40" width="160" height="40" as="geometry"/>
        </mxCell>

        <!-- Lifelines (dashed vertical lines) -->
        <mxCell id="ll_handler" style="endArrow=none;html=1;rounded=0;dashed=1;dashPattern=4 4;strokeColor=#999999;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="150" y="80" as="sourcePoint"/>
            <mxPoint x="150" y="600" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="ll_db" style="endArrow=none;html=1;rounded=0;dashed=1;dashPattern=4 4;strokeColor=#999999;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="390" y="80" as="sourcePoint"/>
            <mxPoint x="390" y="600" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="ll_runner" style="endArrow=none;html=1;rounded=0;dashed=1;dashPattern=4 4;strokeColor=#999999;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="650" y="80" as="sourcePoint"/>
            <mxPoint x="650" y="600" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="ll_svc" style="endArrow=none;html=1;rounded=0;dashed=1;dashPattern=4 4;strokeColor=#999999;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="900" y="80" as="sourcePoint"/>
            <mxPoint x="900" y="600" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Phase 1: Handler writes to DB (in tx) -->
        <!-- Bracket label: same transaction -->
        <mxCell id="tx_label" value="same transaction" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=2;fontColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="115" width="120" height="20" as="geometry"/>
        </mxCell>

        <!-- Arrow 1: handler -> db: business data + queued message -->
        <mxCell id="msg1" value="business data&#xa;+ queued message" style="endArrow=classic;html=1;rounded=0;strokeColor=#6c8ebf;strokeWidth=2;fontSize=12;align=center;verticalAlign=bottom;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="150" y="150" as="sourcePoint"/>
            <mxPoint x="390" y="150" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Arrow 2: db -> handler: COMMIT (dashed return) -->
        <mxCell id="msg2" value="COMMIT" style="endArrow=open;html=1;rounded=0;dashed=1;dashPattern=6 4;strokeColor=#82b366;strokeWidth=2;fontSize=12;fontStyle=1;fontColor=#82b366;align=center;verticalAlign=bottom;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="390" y="200" as="sourcePoint"/>
            <mxPoint x="150" y="200" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Phase 2: Async section -->
        <mxCell id="async_label" value="async" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=2;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="245" width="80" height="20" as="geometry"/>
        </mxCell>

        <!-- Arrow 3: runner -> db: poll & lock -->
        <mxCell id="msg3" value="poll &amp; lock" style="endArrow=classic;html=1;rounded=0;strokeColor=#666666;strokeWidth=2;fontSize=12;align=center;verticalAlign=bottom;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="650" y="280" as="sourcePoint"/>
            <mxPoint x="390" y="280" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Arrow 4: runner -> service: dispatch -->
        <mxCell id="msg4" value="dispatch" style="endArrow=classic;html=1;rounded=0;strokeColor=#666666;strokeWidth=2;fontSize=12;align=center;verticalAlign=bottom;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="650" y="330" as="sourcePoint"/>
            <mxPoint x="900" y="330" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Outcomes box (3 alternatives) -->
        <mxCell id="outcomes" value="result" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#999999;dashed=1;dashPattern=6 4;fontSize=11;fontColor=#666666;verticalAlign=top;arcSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="120" y="380" width="800" height="200" as="geometry"/>
        </mxCell>

        <!-- Success: runner -> db: delete -->
        <mxCell id="branch1" value="success" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=2;fontColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="135" y="410" width="60" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="msg5" value="delete" style="endArrow=classic;html=1;rounded=0;strokeColor=#82b366;strokeWidth=2;fontSize=12;align=center;verticalAlign=bottom;fontColor=#82b366;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="650" y="430" as="sourcePoint"/>
            <mxPoint x="390" y="430" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Separator -->
        <mxCell id="sep1" style="endArrow=none;html=1;rounded=0;dashed=1;dashPattern=2 4;strokeColor=#cccccc;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="135" y="455" as="sourcePoint"/>
            <mxPoint x="905" y="455" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Transient failure: runner -> db: retry later -->
        <mxCell id="branch2" value="transient&#xa;failure" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=2;fontColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="135" y="475" width="80" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="msg6" value="retry later" style="endArrow=classic;html=1;rounded=0;strokeColor=#d6b656;strokeWidth=2;fontSize=12;align=center;verticalAlign=bottom;fontColor=#a18432;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="650" y="495" as="sourcePoint"/>
            <mxPoint x="390" y="495" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Separator -->
        <mxCell id="sep2" style="endArrow=none;html=1;rounded=0;dashed=1;dashPattern=2 4;strokeColor=#cccccc;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="135" y="520" as="sourcePoint"/>
            <mxPoint x="905" y="520" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Max retries: runner -> db: dead letter -->
        <mxCell id="branch3" value="max retries" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=2;fontColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="135" y="540" width="80" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="msg7" value="dead letter" style="endArrow=classic;html=1;rounded=0;strokeColor=#b85450;strokeWidth=2;fontSize=12;align=center;verticalAlign=bottom;fontColor=#b85450;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="650" y="555" as="sourcePoint"/>
            <mxPoint x="390" y="555" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
